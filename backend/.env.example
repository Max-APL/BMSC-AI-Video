APP_NAME=BMSC AI Video Backend
VIDEO_STORAGE_DIR=./storage

# Optional. Use this when the backend process does not inherit ffmpeg from PATH.
# Example: C:\ffmpeg\bin\ffmpeg.exe
FFMPEG_BIN=ffmpeg

# Local ASR. The first run downloads the model unless it already exists locally.
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
# Leave empty for auto language detection.
WHISPER_LANGUAGE=
WHISPER_MODEL_DIR=
WHISPER_AUDIO_CHUNK_SECONDS=300
WHISPER_BEAM_SIZE=5
WHISPER_BEST_OF=5
WHISPER_TEMPERATURE=0.0
WHISPER_CONDITION_ON_PREVIOUS_TEXT=true
# 0 = auto based on available CPU cores. Whisper auto caps high-core CPUs conservatively.
WHISPER_CPU_THREADS=0
WHISPER_NUM_WORKERS=0
WHISPER_CHUNK_WORKERS=1

# Search documents are built from transcript segments.
SEARCH_CHUNK_SECONDS=14
SEARCH_CHUNK_MAX_CHARS=320

# Manual generation. Screenshot count is automatic unless a positive cap is configured.
MANUAL_CHUNK_SECONDS=90
MANUAL_LLM_CHUNK_SECONDS=300
MANUAL_LLM_CHUNK_MAX_CHARS=7000
MANUAL_TERMINOLOGY_HINTS=
MANUAL_SCREENSHOT_OFFSET_SECONDS=2
# 0 = automatic. Positive values cap screenshots globally per manual.
MANUAL_SCREENSHOT_MIN_GAP_SECONDS=45
MANUAL_SCREENSHOT_MAX_COUNT=0
MANUAL_LLM_SCREENSHOT_MAX_COUNT=0
MANUAL_SCREENSHOT_WIDTH=1280

# Local LLM. For CPU-only runs, keep LLM_N_GPU_LAYERS=0.
LLM_PROVIDER=llama_cpp
LLM_MODEL=Llama-3.2-3B-Instruct-Q4_K_M
LLM_MODEL_PATH=
LLM_N_GPU_LAYERS=0
# 0 = auto based on available CPU cores.
LLM_N_THREADS=0
LLM_N_THREADS_BATCH=0
LLM_N_BATCH=0
LLM_N_UBATCH=512
LLM_MAX_TOKENS_ANSWER=256
LLM_MAX_TOKENS_SECTION=1000
LLM_NUM_CTX=0
LLM_TIMEOUT_SECONDS=900
LLM_TEMPERATURE=0.2

# Future frontend origins. Use * during local prototyping if needed.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
