APP_NAME=BMSC AI Video Backend
VIDEO_STORAGE_DIR=./storage
# Keep Hugging Face model downloads inside the backend folder for offline deployments.
HF_HOME=./models_cache/huggingface

# Security and session settings.
# Use a long random value in production.
JWT_SECRET_KEY=change-this-secret-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080
EMAIL_BRAND_NAME=AI Video
AUTH_MAX_FAILED_LOGIN_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15
AUTH_CODE_EXPIRE_MINUTES=15
AUTH_CODE_MAX_ATTEMPTS=5

# Optional. Use this when the backend process does not inherit ffmpeg from PATH.
# Example: C:\ffmpeg\bin\ffmpeg.exe
FFMPEG_BIN=ffmpeg

# Single backend inference switch.
# Use cpu for CPU-only servers, cuda for NVIDIA GPU servers.
INFERENCE_DEVICE=cpu

# Local ASR with faster-whisper.
# Leave WHISPER_LANGUAGE empty for automatic Spanish/English detection.
WHISPER_MODEL=base
# Advanced override. Leave empty to derive from INFERENCE_DEVICE.
WHISPER_DEVICE=
WHISPER_COMPUTE_TYPE=
WHISPER_LANGUAGE=
WHISPER_MODEL_DIR=
WHISPER_AUDIO_CHUNK_SECONDS=300
WHISPER_BEAM_SIZE=5
WHISPER_BEST_OF=5
WHISPER_TEMPERATURE=0.0
WHISPER_CONDITION_ON_PREVIOUS_TEXT=true
# 0 = auto based on available CPU cores.
WHISPER_CPU_THREADS=0
WHISPER_NUM_WORKERS=0
WHISPER_CHUNK_WORKERS=1

# Search documents are built from transcript segments.
SEARCH_CHUNK_SECONDS=14
SEARCH_CHUNK_MAX_CHARS=320

# Manual generation.
# Screenshot count is automatic unless a positive cap is configured.
MANUAL_CHUNK_SECONDS=90
MANUAL_LLM_CHUNK_SECONDS=300
MANUAL_LLM_CHUNK_MAX_CHARS=7000
# Optional comma-separated terminology hints for the current deployment/domain.
# Leave empty to avoid biasing manuals toward a specific video.
MANUAL_TERMINOLOGY_HINTS=
MANUAL_SCREENSHOT_OFFSET_SECONDS=2
# 0 = automatic. Positive values cap screenshots globally per manual.
MANUAL_SCREENSHOT_MIN_GAP_SECONDS=45
MANUAL_SCREENSHOT_MAX_COUNT=0
MANUAL_LLM_SCREENSHOT_MAX_COUNT=0
MANUAL_SCREENSHOT_WIDTH=1280
# Manual generation profiles.
MANUAL_QUALITY_MODE_DEFAULT=fast
MANUAL_QUALITY_MAX_LOOPS=1
MANUAL_FAST_MAX_IMAGES=8
MANUAL_QUALITY_MAX_IMAGES=16
MANUAL_MIN_IMAGE_QUALITY_SCORE=0.35
MANUAL_MIN_REVIEW_SCORE=0.78
# Hugging Face CPU model used by quality mode to validate screenshots.
MANUAL_VISION_MODEL=HuggingFaceTB/SmolVLM-500M-Instruct

# Local LLM via llama-cpp-python.
# Advanced override. Leave empty to derive from INFERENCE_DEVICE.
# In production/offline, LLM_MODEL_PATH must point to an existing GGUF file.
LLM_PROVIDER=llama_cpp
LLM_MODEL_REPO_ID=bartowski/Llama-3.2-3B-Instruct-GGUF
LLM_MODEL_FILENAME=Llama-3.2-3B-Instruct-Q4_K_M.gguf
LLM_MODEL=Llama-3.2-3B-Instruct-Q4_K_M.gguf
LLM_MODEL_PATH=./models_cache/llm/Llama-3.2-3B-Instruct-Q4_K_M.gguf
LLM_N_GPU_LAYERS=
# 0 = auto based on available CPU cores.
LLM_N_THREADS=0
LLM_N_THREADS_BATCH=0
LLM_N_BATCH=512
LLM_N_UBATCH=512
LLM_MAX_TOKENS_ANSWER=256
LLM_MAX_TOKENS_SECTION=1000
LLM_NUM_CTX=8192
LLM_TIMEOUT_SECONDS=900
LLM_TEMPERATURE=0.2

# Frontend origins.
# Production frontend: http://172.28.18.120:4173
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:4173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:5174,http://127.0.0.1:4173,http://127.0.0.1:3000,http://172.28.18.120:4173
CORS_ORIGIN_REGEX=^http://(localhost|127\.0\.0\.1|172\.28\.18\.120):\d+$


# SMTP email delivery.
# Local Mailpit test server:
# docker run --rm --name mailpit -p 1025:1025 -p 8025:8025 axllent/mailpit
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=no-reply@bmsc.local
SMTP_TIMEOUT=10
SMTP_ENABLED=true

# Production bank relay, only reachable inside the bank network:
# SMTP_HOST=172.16.17.171
# SMTP_PORT=25
# SMTP_FROM=noreply@bmsc.com.bo
# SMTP_TIMEOUT=10
# SMTP_ENABLED=true
