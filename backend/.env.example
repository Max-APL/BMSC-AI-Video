APP_NAME=BMSC AI Video Backend
VIDEO_STORAGE_DIR=./storage

# Optional. Use this when the backend process does not inherit ffmpeg from PATH.
# Example: C:\ffmpeg\bin\ffmpeg.exe
FFMPEG_BIN=ffmpeg

# Local ASR with faster-whisper.
# Leave WHISPER_LANGUAGE empty for automatic Spanish/English detection.
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=
WHISPER_MODEL_DIR=
WHISPER_AUDIO_CHUNK_SECONDS=300
WHISPER_BEAM_SIZE=5
WHISPER_BEST_OF=5
WHISPER_TEMPERATURE=0.0
WHISPER_CONDITION_ON_PREVIOUS_TEXT=true
# 0 = auto based on available CPU cores.
WHISPER_CPU_THREADS=0
WHISPER_NUM_WORKERS=0
WHISPER_CHUNK_WORKERS=1

# Search documents are built from transcript segments.
SEARCH_CHUNK_SECONDS=14
SEARCH_CHUNK_MAX_CHARS=320

# Manual generation.
# Screenshot count is automatic unless a positive cap is configured.
MANUAL_CHUNK_SECONDS=90
MANUAL_LLM_CHUNK_SECONDS=300
MANUAL_LLM_CHUNK_MAX_CHARS=7000
# Optional comma-separated terminology hints for the current deployment/domain.
# Leave empty to avoid biasing manuals toward a specific video.
MANUAL_TERMINOLOGY_HINTS=
MANUAL_SCREENSHOT_OFFSET_SECONDS=2
# 0 = automatic. Positive values cap screenshots globally per manual.
MANUAL_SCREENSHOT_MIN_GAP_SECONDS=45
MANUAL_SCREENSHOT_MAX_COUNT=0
MANUAL_LLM_SCREENSHOT_MAX_COUNT=0
MANUAL_SCREENSHOT_WIDTH=1280

# Local LLM via llama-cpp-python.
# For CPU-only servers, keep LLM_N_GPU_LAYERS=0.
# In production/offline, LLM_MODEL_PATH must point to an existing GGUF file.
LLM_PROVIDER=llama_cpp
LLM_MODEL=Meta-Llama-3.1-8B-Instruct-Q4_K_M.gguf
LLM_MODEL_PATH=./models_cache/llm/Meta-Llama-3.1-8B-Instruct-Q4_K_M.gguf
LLM_N_GPU_LAYERS=0
# 0 = auto based on available CPU cores.
LLM_N_THREADS=0
LLM_N_THREADS_BATCH=0
LLM_N_BATCH=512
LLM_N_UBATCH=512
LLM_MAX_TOKENS_ANSWER=256
LLM_MAX_TOKENS_SECTION=1000
LLM_NUM_CTX=8192
LLM_TIMEOUT_SECONDS=900
LLM_TEMPERATURE=0.2

# Frontend origins.
# Production frontend: http://172.28.18.120:4173
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:4173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:5174,http://127.0.0.1:4173,http://127.0.0.1:3000,http://172.28.18.120:4173
CORS_ORIGIN_REGEX=^http://(localhost|127\.0\.0\.1|172\.28\.18\.120):\d+$
